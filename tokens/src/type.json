{
  "font": {
    "family": {
      "$type": "fontFamily",
      "display":    { "$value": "{family.display}" },
      "serif-body": { "$value": "{family.serif-body}" },
      "base":       { "$value": "{family.base}" }
    },
    "size": {
      "$type": "dimension",
      "display-l":  { "$value": "3.25rem" },
      "display-m":  { "$value": "2.5rem" },
      "headline-l": { "$value": "2rem" },
      "headline-m": { "$value": "1.5rem" },
      "title":      { "$value": "1.25rem" },
      "body-l":     { "$value": "1.125rem" },
      "body-m":     { "$value": "1rem" },
      "label":      { "$value": "0.9375rem" },
      "meta":       { "$value": "0.8125rem" }
    },
    "leading": {
      "$type": "number",
      "tight":   { "$value": 1.15 },
      "snug":    { "$value": 1.3 },
      "regular": { "$value": 1.55 }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": "{weight.regular}" },
      "medium":   { "$value": "{weight.medium}" },
      "semibold": { "$value": "{weight.semibold}" }
    }
  }
}
