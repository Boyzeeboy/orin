{
  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": "{family.display}" },
      "base":    { "$value": "{family.base}" }
    },
    "size": {
      "$type": "dimension",
      "100":  { "$value": "0.6875rem" },
      "200":  { "$value": "0.75rem" },
      "300":  { "$value": "0.875rem" },
      "400":  { "$value": "1rem" },
      "500":  { "$value": "1.125rem" },
      "600":  { "$value": "1.5rem" },
      "700":  { "$value": "1.75rem" },
      "800":  { "$value": "2rem" },
      "900":  { "$value": "2.25rem" },
      "1000": { "$value": "2.75rem" },
      "1100": { "$value": "3.5rem" }
    },
    "leading": {
      "$type": "number",
      "tight":   { "$value": 1.15 },
      "snug":    { "$value": 1.3 },
      "regular": { "$value": 1.55 }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": "{weight.regular}" },
      "medium":   { "$value": "{weight.medium}" },
      "semibold": { "$value": "{weight.semibold}" }
    }
  }
}
